# ==============================================================================
# Application Settings
# ==============================================================================
DEBUG=True
APP_NAME=WMS-Light

# ==============================================================================
# Database Settings
# ==============================================================================
# Для локальной разработки без Докера используй localhost
# Для запуска в Docker-контексте укажи имя сервиса базы данных (например, db)
DB__DATABASE_HOST=localhost
DB__DATABASE_PORT=5432
DB__DATABASE_USER=your_db_user
DB__DATABASE_PASSWORD=your_db_password
DB__DATABASE_NAME=your_db_name
DB__DATABASE_SSL=disable

# ==============================================================================
# Security Settings (Задел на будущее для JWT)
# ==============================================================================
# Сгенерируй надежный ключ командой: openssl rand -hex 32
SECRET_KEY=your_super_secret_jwt_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30